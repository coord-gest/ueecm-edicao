# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no repositório.

# ─── Supabase ─────────────────────────────────────────────────────────────────

# Chave pública do Supabase (anon key) — pode ser exposta no cliente
SUPABASE_URL="https://xxkurtwcwmgcuyvqfoiq.supabase.co"
SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL="https://xxkurtwcwmgcuyvqfoiq.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID="xxkurtwcwmgcuyvqfoiq"

# Chave secreta do Supabase (service_role) — APENAS servidor, nunca expor no cliente
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Firebase Cloud Messaging (FCM) ───────────────────────────────────────────
# Push notifications via FCM HTTP v1. Cadastre no Cloudflare via `wrangler secret put`:
#   FIREBASE_PROJECT_ID, FIREBASE_CLIENT_EMAIL, FIREBASE_PRIVATE_KEY,
#   FIREBASE_VAPID_PUBLIC_KEY, FIREBASE_WEB_API_KEY
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_VAPID_PUBLIC_KEY=""
FIREBASE_WEB_API_KEY=""

# Protege /api/public/dispatch-push
DISPATCH_SECRET=""

