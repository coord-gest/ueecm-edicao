{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "conectaueecm",
  "main": "./dist/server/index.mjs",
  "compatibility_date": "2026-06-12",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client",
  },
  "observability": {
    "enabled": true,
  },
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": ["**/*.mjs", "**/*.js"],
    },
  ],
}
